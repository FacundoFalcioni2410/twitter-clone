// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique @db.VarChar(254)
  username       String   @unique @db.VarChar(20)
  name           String   @db.VarChar(50)
  bio            String?  @db.VarChar(160)
  avatarUrl      String?  @db.VarChar(500)
  passwordHash   String   @db.VarChar(60)
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tweets         Tweet[]
  followers      Follow[] @relation("FollowTarget")
  following      Follow[] @relation("FollowSource")
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Tweet {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(280)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}
